# App runtime
RPA_ENV=development
RPA_LOG_LEVEL=INFO
RPA_PERSONA_PATH=configs/personas/default.toml
RPA_DATA_DIR=./data
RPA_CACHE_DIR=./.cache/rpa

# Platform and acceleration
RPA_PLATFORM=windows
RPA_DEVICE=auto
RPA_ACCELERATOR=auto

# Provider selection: mock | openai | anthropic | elevenlabs | ollama | vllm | local
RPA_ASR_PROVIDER=mock
RPA_VISION_PROVIDER=mock
RPA_LLM_PROVIDER=mock
RPA_TTS_PROVIDER=mock
RPA_ANIMATION_PROVIDER=mock

# Model selection
RPA_ASR_MODEL=whisper-small
RPA_VISION_MODEL=gpt-4o-mini
RPA_LLM_MODEL=gpt-4o-mini
RPA_TTS_MODEL=eleven_multilingual_v2
RPA_ANIMATION_MODEL=liveportrait

# IO and latency
RPA_CAMERA_DEVICE=0
RPA_MIC_DEVICE=default
RPA_TARGET_FPS=30
RPA_MAX_LATENCY_MS=500

# Cloud providers
OPENAI_API_KEY=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=

# Local model servers
OLLAMA_BASE_URL=http://localhost:11434
VLLM_BASE_URL=http://localhost:8000
WHISPER_SERVER_URL=http://localhost:9000
TTS_SERVER_URL=http://localhost:5002
ANIMATION_SERVER_URL=http://localhost:7000
